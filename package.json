{
  "name": "open-nbj-tools",
  "version": "0.1.0",
  "description": "Free tools built for other that appreciate it.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write ./src",
    "generate_available_locales": "node scripts/generate-available-locales.mjs",
    "extract_translations": "formatjs extract \"src/**/*.{ts,tsx}\" --out-file src/i18n/extracted/en.json",
    "push_translations": "crowdin upload",
    "pull_translations": "crowdin download && pnpm run generate_available_locales",
    "compile_translations": "formatjs compile-folder src/i18n/extracted src/i18n/compiled",
    "translations": "pnpm run extract_translations && pnpm run push_translations && pnpm run pull_translations && pnpm run compile_translations",
    "generate_openapi": "next-rest-framework generate --configPath /api/docs"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@crowdin/cli": "^4.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-rest-framework": "^6.1.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.3",
    "react-intl": "^8.1.3",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.13.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.32.4"
  }
}
